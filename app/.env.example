# Configuración de la SPA. Copia a `.env` (gitignored). Nada aquí es secreto:
# los client IDs de Google son públicos; los tokens viven solo en el navegador.

# --- Transporte remoto (BFF Google en Vercel), opcional ---
# VITE_AUTH_MODE=remote

# --- Transporte local (daemon en la misma máquina) ---
# VITE_DAEMON_HTTP=http://127.0.0.1:7431
# VITE_DAEMON_WS=ws://127.0.0.1:7431/v1/ws

# --- Transporte relay C-2 (Google Sign-In → device_token) ---
# Base del relay. En producción, añade también estos orígenes a la CSP de
# app/index.html (connect-src).
VITE_RELAY_HTTP=http://127.0.0.1:8443
VITE_RELAY_WS=ws://127.0.0.1:8443
# Client ID **Web** de Google (GIS). Vacío ⇒ solo login "dev" (RELAY_GOOGLE_DEV).
VITE_GOOGLE_CLIENT_ID=
