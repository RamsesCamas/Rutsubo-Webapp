---
// Autenticación. Dos caminos que entregan la credencial a la SPA por fragmento
// de URL (#…), que nunca viaja a ningún servidor:
//   1) Relay C-2 (Google Sign-In): GIS → id_token → canje en el relay
//      (POST /v1/auth/google) → device_token → #device_token=. Unifica la
//      cuenta con el móvil/escritorio.
//   2) Token local del daemon (#token=): "modo completamente local" (RNF-11).
import Base from "../layouts/Base.astro";

// En dev la SPA corre en 5173 (Vite); en producción se sirve junto a esta
// superficie bajo /app/.
const spaUrl = import.meta.env.DEV ? "http://localhost:5173/" : "/app/";
// Config del relay (públicos, no secretos). Client ID **Web** de Google + base
// del relay. Vacío ⇒ el botón de Google se oculta y solo queda el token local.
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? "";
const relayHttp = import.meta.env.PUBLIC_RELAY_HTTP ?? "http://127.0.0.1:8443";
---

<Base
  title="Rutsubo — Iniciar sesión"
  description="Inicia sesión en Rutsubo con Google o con el token local del daemon."
>
  <main class="login">
    <h1>Iniciar sesión</h1>

    {googleClientId && (
      <>
        <button
          id="google-btn"
          type="button"
          class="google"
          data-client-id={googleClientId}
          data-relay-http={relayHttp}
          data-spa-url={spaUrl}
        >
          Continuar con Google
        </button>
        <p id="google-error" class="error" hidden></p>
        <hr />
      </>
    )}

    <p>
      O pega el token local del daemon. Está en
      <code>~/.local/share/rutsubo/token</code> y se generó en el primer
      arranque.
    </p>
    <form id="login-form" data-spa-url={spaUrl}>
      <label for="token">Token del daemon</label>
      <input id="token" name="token" type="password" required autocomplete="off" />
      <button type="submit">Conectar</button>
    </form>
    <p class="hint">
      La credencial viaja solo en el fragmento de la URL (nunca al servidor) y se
      guarda en <code>sessionStorage</code>: muere al cerrar la pestaña.
    </p>
    <p><a href="/">← volver</a></p>
  </main>
</Base>

<script>
  // Vanilla mínimo (no framework): entrega la credencial a la SPA vía #fragment.
  const form = document.getElementById("login-form") as HTMLFormElement;
  form.addEventListener("submit", (event) => {
    event.preventDefault();
    const token = (document.getElementById("token") as HTMLInputElement).value.trim();
    if (!token) return;
    const spaUrl = form.dataset.spaUrl ?? "/app/";
    window.location.href = `${spaUrl}#token=${encodeURIComponent(token)}`;
  });

  // Google Sign-In (relay C-2): GIS → id_token → canje → #device_token=.
  const gbtn = document.getElementById("google-btn") as HTMLButtonElement | null;
  if (gbtn) {
    const clientId = gbtn.dataset.clientId!;
    const relayHttp = gbtn.dataset.relayHttp!;
    const spaUrl = gbtn.dataset.spaUrl ?? "/app/";
    const errEl = document.getElementById("google-error") as HTMLParagraphElement;
    const fail = (msg: string) => {
      errEl.textContent = msg;
      errEl.hidden = false;
      gbtn.disabled = false;
    };
    const emailFromJwt = (jwt: string): string => {
      try {
        return JSON.parse(atob(jwt.split(".")[1])).email ?? "";
      } catch {
        return "";
      }
    };
    const exchange = async (idToken: string) => {
      const res = await fetch(`${relayHttp}/v1/auth/google`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id_token: idToken, device: { kind: "web", name: "Navegador" } }),
      });
      if (!res.ok) throw new Error(`canje rechazado (${res.status})`);
      const { device_token } = (await res.json()) as { device_token: string };
      const email = emailFromJwt(idToken);
      window.location.href =
        `${spaUrl}#device_token=${encodeURIComponent(device_token)}` +
        (email ? `&email=${encodeURIComponent(email)}` : "");
    };
    gbtn.addEventListener("click", () => {
      gbtn.disabled = true;
      errEl.hidden = true;
      const script = document.createElement("script");
      script.src = "https://accounts.google.com/gsi/client";
      script.async = true;
      script.onload = () => {
        const google = (window as unknown as { google?: any }).google;
        if (!google?.accounts?.id) return fail("GIS no disponible");
        google.accounts.id.initialize({
          client_id: clientId,
          callback: (r: { credential: string }) =>
            exchange(r.credential).catch((e) => fail(String(e?.message ?? e))),
        });
        google.accounts.id.prompt();
      };
      script.onerror = () => fail("no se pudo cargar Google Sign-In");
      document.head.appendChild(script);
    });
  }
</script>

<style>
  .login {
    max-width: 28rem;
    margin: 10vh auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  h1 {
    margin: 0;
  }
  form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  label {
    font-weight: 600;
  }
  input {
    font: inherit;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: #fffefb;
  }
  button {
    font: inherit;
    font-weight: 600;
    background: var(--sage);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.6rem;
    cursor: pointer;
  }
  button:hover,
  button:focus-visible {
    background: var(--sage-dark);
  }
  .google {
    background: #fff;
    color: var(--graphite);
    border: 1px solid var(--line);
    font-weight: 600;
  }
  .google:hover,
  .google:focus-visible {
    background: #f2f1ec;
  }
  .google:disabled {
    opacity: 0.6;
    cursor: default;
  }
  hr {
    width: 100%;
    border: none;
    border-top: 1px solid var(--line);
    margin: 0.4rem 0;
  }
  .error {
    color: #a3341f;
    font-size: 0.88rem;
    margin: 0;
  }
  .hint {
    color: var(--graphite-soft);
    font-size: 0.88rem;
  }
  code {
    background: #ecefe9;
    padding: 0 0.3em;
    border-radius: 3px;
  }
</style>
