# Superficie pública (Astro). Copia a `.env` (gitignored). Nada es secreto.
# Login del relay con Google (opcional): si defines el client ID, aparece el
# botón "Continuar con Google" que canjea el id_token en el relay y entrega el
# device_token a la SPA por #device_token=.
PUBLIC_GOOGLE_CLIENT_ID=
PUBLIC_RELAY_HTTP=http://127.0.0.1:8443
